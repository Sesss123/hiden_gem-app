<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-6">
    <div>
        <p class="text-gray-500 text-sm">Centralized repository for high-resolution tourism assets and media files.</p>
    </div>
    <div class="flex items-center gap-3">
        <form action="/media/upload" method="POST" enctype="multipart/form-data" class="flex items-center gap-3">
            <input type="file" name="media" required class="text-xs text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-[10px] file:font-bold file:bg-gray-100 file:text-gray-600 file:uppercase file:tracking-widest hover:file:bg-gray-200 cursor-pointer">
            <button type="submit" class="bg-gray-800 hover:bg-gray-900 text-white font-bold py-2.5 px-6 rounded-xl transition shadow-lg shadow-gray-200 text-[10px] uppercase tracking-widest">
                Ingest Asset
            </button>
        </form>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
    <% assets.forEach(asset => { %>
        <div class="premium-card p-0 overflow-hidden group">
            <div class="aspect-square bg-gray-50 flex items-center justify-center relative">
                <% if (asset.mimeType.startsWith('image/')) { %>
                    <img src="<%= asset.url %>" class="w-full h-full object-cover transition duration-500 group-hover:scale-105">
                <% } else { %>
                    <svg class="w-12 h-12 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.707 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                <% } %>
                
                <!-- Actions Overlay -->
                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition flex items-center justify-center gap-4">
                    <a href="<%= asset.url %>" target="_blank" class="p-2 bg-white rounded-lg text-gray-800 hover:bg-gray-100 transition" title="View Full Resource">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                    </a>
                    <form action="/media/<%= asset._id %>/delete" method="POST" onsubmit="return confirm('Archive this asset permanently?')">
                        <button type="submit" class="p-2 bg-white rounded-lg text-red-500 hover:bg-red-50 transition" title="Purge Asset">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        </button>
                    </form>
                </div>
            </div>
            <div class="p-4 border-t border-gray-50">
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest truncate" title="<%= asset.originalName %>"><%= asset.originalName %></p>
                <div class="flex items-center justify-between mt-2">
                    <span class="text-[9px] font-bold text-gray-400"><%= (asset.size / 1024).toFixed(1) %> KB</span>
                    <span class="text-[9px] font-mono font-bold text-indigo-400 uppercase tracking-tight"><%= asset.mimeType.split('/')[1] %></span>
                </div>
            </div>
        </div>
    <% }) %>

    <% if (assets.length === 0) { %>
        <div class="col-span-full py-20 text-center bg-gray-50/50 rounded-2xl border-2 border-dashed border-gray-100 transition hover:bg-gray-50 cursor-pointer">
            <svg class="w-12 h-12 text-gray-200 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            <p class="text-gray-400 text-sm font-bold uppercase tracking-widest">Awaiting First Upload</p>
        </div>
    <% } %>
</div>
