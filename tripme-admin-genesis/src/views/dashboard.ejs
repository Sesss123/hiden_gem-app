<!-- Stats Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="premium-card p-6">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Total Places</p>
        <div class="flex items-end justify-between">
            <h3 class="text-3xl font-bold text-gray-800"><%= stats.totalPlaces %></h3>
            <span class="text-green-600 text-xs font-bold">+12% &uarr;</span>
        </div>
    </div>
    <div class="premium-card p-6 border-l-4 border-l-green-500">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Approved</p>
        <div class="flex items-end justify-between">
            <h3 class="text-3xl font-bold text-gray-800"><%= stats.approvedPlaces %></h3>
            <span class="text-gray-400 text-xs font-medium">Safe Node</span>
        </div>
    </div>
    <div class="premium-card p-6 border-l-4 border-l-orange-400">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Pending Review</p>
        <div class="flex items-end justify-between">
            <h3 class="text-3xl font-bold text-gray-800"><%= stats.pendingPlaces %></h3>
            <a href="/reviews" class="text-indigo-600 text-xs font-bold hover:underline">Action Required</a>
        </div>
    </div>
    <div class="premium-card p-6">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Active Admins</p>
        <div class="flex items-end justify-between">
            <h3 class="text-3xl font-bold text-gray-800"><%= stats.totalUsers %></h3>
            <div class="flex -space-x-2">
                <div class="w-6 h-6 rounded-full bg-gray-200 border-2 border-white"></div>
                <div class="w-6 h-6 rounded-full bg-gray-300 border-2 border-white"></div>
            </div>
        </div>
    </div>
</div>

<!-- Smart Intake Command (NEW) -->
<div class="premium-card p-6 mb-8 bg-gradient-to-r from-indigo-50 to-white border-l-4 border-l-indigo-600">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div class="flex-1">
            <h4 class="font-bold text-gray-800 text-lg mb-1 flex items-center gap-2">
                <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                Smart HTML Intake
            </h4>
            <p class="text-xs text-gray-500">Provide any web URL. AI will automatically scrape, clean, and extract tourism data into a draft registry.</p>
        </div>
        <div class="flex-1 max-w-xl">
            <div class="flex gap-2">
                <div class="relative flex-1">
                    <input type="url" id="smartIntakeUrl" 
                           placeholder="https://example.com/tourist-attraction" 
                           class="w-full bg-white border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition">
                </div>
                <button onclick="handleSmartIntake()" id="intakeBtn"
                        class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-lg text-sm font-bold transition flex items-center gap-2 whitespace-nowrap">
                    <span id="intakeBtnText">Initialize Extraction</span>
                    <div id="intakeSpinner" class="hidden w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                </button>
            </div>
        </div>
    </div>
    
    <!-- Result Preview (Hidden Initially) -->
    <div id="intakeResult" class="hidden mt-6 pt-6 border-t border-indigo-100 animate-in fade-in slide-in-from-top-4 duration-500">
        <div class="flex items-start gap-4">
            <div id="intakeImage" class="w-24 h-24 rounded-lg bg-gray-100 bg-cover bg-center shrink-0 border border-gray-200"></div>
            <div class="flex-1">
                <div class="flex items-center justify-between mb-2">
                    <h5 id="intakeName" class="font-bold text-gray-800 text-base">---</h5>
                    <span id="intakeCategory" class="px-2 py-0.5 bg-indigo-100 text-indigo-700 rounded text-[10px] font-bold uppercase tracking-wider">---</span>
                </div>
                <p id="intakeDesc" class="text-xs text-gray-500 line-clamp-2 mb-3">---</p>
                <div class="flex items-center gap-4 text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-3">
                    <span class="flex items-center gap-1">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        <span id="intakeDistrict">---</span>
                    </span>
                    <span class="flex items-center gap-1">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <span id="intakePrice">---</span>
                    </span>
                </div>
                
                <!-- Extra Intelligence Grid -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-2 p-3 bg-white/50 rounded-lg border border-indigo-50">
                    <div>
                        <p class="text-[9px] text-gray-400 uppercase font-black tracking-tighter">Logistics</p>
                        <p id="intakeLogistics" class="text-[10px] text-gray-800 font-semibold mt-0.5">---</p>
                    </div>
                    <div>
                        <p class="text-[9px] text-gray-400 uppercase font-black tracking-tighter">Mobile Signal</p>
                        <p id="intakeSignal" class="text-[10px] text-gray-800 font-semibold mt-0.5">---</p>
                    </div>
                    <div>
                        <p class="text-[9px] text-gray-400 uppercase font-black tracking-tighter">Safety</p>
                        <p id="intakeSafety" class="text-[10px] text-gray-800 font-semibold mt-0.5">---</p>
                    </div>
                    <div>
                        <p class="text-[9px] text-gray-400 uppercase font-black tracking-tighter">Best Time</p>
                        <p id="intakeTime" class="text-[10px] text-gray-800 font-semibold mt-0.5">---</p>
                    </div>
                </div>
            </div>
            <div class="flex flex-col gap-2">
                <a id="intakeRefineLink" href="#" class="bg-emerald-500 hover:bg-emerald-600 text-white px-4 py-2 rounded-lg text-[10px] font-bold uppercase tracking-widest text-center transition">Refine & Approve</a>
                <button onclick="document.getElementById('intakeResult').classList.add('hidden')" class="text-[10px] font-bold text-gray-400 hover:text-gray-600 uppercase tracking-widest py-1 transition">Discard</button>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Recent Inventory -->
    <div class="lg:col-span-2 space-y-6">
        <div class="premium-card overflow-hidden">
            <div class="p-6 border-b border-gray-100 flex items-center justify-between">
                <h4 class="font-bold text-gray-800">Fresh Nodes</h4>
                <a href="/places" class="text-xs font-bold text-indigo-600 uppercase tracking-wider hover:text-indigo-800">View Registry</a>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-gray-50 text-[10px] uppercase font-bold text-gray-500 tracking-widest border-b border-gray-100">
                        <tr>
                            <th class="px-6 py-4">Resource Identity</th>
                            <th class="px-6 py-4">Context</th>
                            <th class="px-6 py-4">Health</th>
                            <th class="px-6 py-4 text-right">Registry Date</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        <% recentPlaces.forEach(place => { %>
                            <tr class="hover:bg-gray-50/50 transition cursor-pointer" onclick="window.location='/places/<%= place._id %>'">
                                <td class="px-6 py-4 text-sm font-semibold text-gray-800"><%= place.name %></td>
                                <td class="px-6 py-4">
                                    <span class="bg-gray-100 text-gray-600 text-[10px] px-2 py-0.5 rounded-full uppercase font-bold"><%= place.district %></span>
                                </td>
                                 <td class="px-6 py-4">
                                         <div class="w-16 h-1.5 bg-gray-100 rounded-full overflow-hidden">
                                             <div class="h-full bg-indigo-500 rounded-full" style="--p: <%= place.score || 0 %>%; width: var(--p);"></div>
                                         </div>
                                 </td>
                                <td class="px-6 py-4 text-right text-xs text-gray-400 font-mono"><%= place.createdAt.toISOString().split('T')[0] %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- System Activity -->
    <div class="space-y-6">
        <div class="premium-card p-6">
            <h4 class="font-bold text-gray-800 mb-4">Command History</h4>
            <div class="space-y-4">
                <% recentActivity.forEach(log => { %>
                    <div class="flex gap-4">
                        <div class="mt-1 w-2 h-2 rounded-full bg-indigo-200 ring-4 ring-indigo-50"></div>
                        <div>
                            <p class="text-xs font-semibold text-gray-800 leading-tight">
                                <span class="text-indigo-600"><%= log.actorName %></span> <%= log.action.toLowerCase().replace('_', ' ') %> <%= log.entityType.toLowerCase() %>
                            </p>
                            <p class="text-[10px] text-gray-400 mt-0.5"><%= log.createdAt.toLocaleTimeString() %></p>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- AI Budget Monitor (NEW) -->
        <div class="premium-card p-6 bg-gradient-to-br from-gray-900 to-gray-800 text-white border-0">
            <div class="flex items-center justify-between mb-4">
                <h4 class="font-bold text-sm">AI Budget & Usage</h4>
                <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div class="space-y-4">
                <div class="flex justify-between items-end">
                    <div>
                        <p class="text-[10px] text-gray-400 uppercase font-black tracking-tighter">Estimated Cost</p>
                        <h3 class="text-2xl font-mono text-emerald-400">$<%= (analytics.ai_usage?.total_cost || 0).toFixed(4) %></h3>
                    </div>
                    <div class="text-right">
                        <p class="text-[10px] text-gray-400 uppercase font-black tracking-tighter">Total Tokens</p>
                        <p class="text-xs font-mono"><%= (analytics.ai_usage?.total_tokens || 0).toLocaleString() %></p>
                    </div>
                </div>
                <div class="pt-2 border-t border-white/10">
                    <p class="text-[9px] text-gray-500 uppercase font-bold mb-2">Model Breakdown</p>
                    <% if (analytics.ai_usage?.model_breakdown) { %>
                        <% Object.entries(analytics.ai_usage.model_breakdown).forEach(([model, data]) => { %>
                            <div class="flex justify-between text-[10px] mb-1">
                                <span class="text-gray-400"><%= model %></span>
                                <span class="font-mono">$<%= data.cost.toFixed(4) %></span>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-[10px] text-gray-600 italic">No usage data synced.</p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Pipeline Status -->
        <div class="premium-card p-6 <%= (analytics.recent_runs && analytics.recent_runs[0]?.status === 'running') ? 'bg-indigo-900 border-0 shadow-lg shadow-indigo-200 text-white' : 'bg-white' %>">
            <% const currentRun = (analytics.recent_runs && analytics.recent_runs[0]?.status === 'running') ? analytics.recent_runs[0] : null; %>
            
            <div class="flex items-center justify-between mb-4">
                <h4 class="font-bold text-sm">AI Pipeline Status</h4>
                <% if (currentRun) { %>
                    <div class="px-2 py-0.5 bg-indigo-700 rounded text-[10px] font-bold uppercase tracking-widest animate-pulse">Running</div>
                <% } else { %>
                    <div class="px-2 py-0.5 bg-gray-100 text-gray-500 rounded text-[10px] font-bold uppercase tracking-widest">Idle</div>
                <% } %>
            </div>

            <% if (currentRun) { %>
                <div class="space-y-3">
                    <div class="flex justify-between text-xs">
                        <span class="<%= currentRun ? 'text-indigo-300' : 'text-gray-400' %> truncate mr-2"><%= currentRun.name %></span>
                        <span class="font-mono"><%= currentRun.progress %>%</span>
                    </div>
                    <div class="w-full bg-indigo-800/50 rounded-full h-1.5">
                        <div class="bg-indigo-400 h-1.5 rounded-full transition-all duration-500" style="--p: <%= currentRun.progress || 0 %>%; width: var(--p);"></div>
                    </div>
                    <div class="flex justify-between items-center pt-2">
                        <button onclick="handleStopPipeline('<%= currentRun.id %>')" class="text-[10px] font-bold uppercase bg-red-500/20 hover:bg-red-500 text-red-500 hover:text-white px-3 py-1.5 rounded-lg transition">Emergency Stop</button>
                        <a href="/pipeline" class="text-[10px] font-bold uppercase bg-white/10 hover:bg-white/20 px-3 py-1.5 rounded-lg transition">Details</a>
                    </div>
                </div>
            <% } else { %>
                <p class="text-xs text-gray-500 leading-relaxed mb-4">No active background discovery jobs detect. System standing by for manual injection.</p>
                <a href="/pipeline" class="inline-block text-[10px] font-bold uppercase border border-gray-200 hover:border-indigo-600 hover:text-indigo-600 px-4 py-2 rounded-lg transition">Start Discovery</a>
            <% } %>
        </div>
    </div>
</div>

<script>
async function handleSmartIntake() {
    const urlInput = document.getElementById('smartIntakeUrl');
    const url = urlInput.value.trim();
    const btn = document.getElementById('intakeBtn');
    const btnText = document.getElementById('intakeBtnText');
    const spinner = document.getElementById('intakeSpinner');
    const resultPanel = document.getElementById('intakeResult');

    if (!url) {
        alert('Please enter a valid URL.');
        return;
    }

    // UI Feedback: Loading
    btn.disabled = true;
    btn.classList.add('opacity-80', 'cursor-not-allowed');
    btnText.innerText = 'Extracting...';
    spinner.classList.remove('hidden');
    resultPanel.classList.add('hidden');

    try {
        const response = await fetch('/pipeline/smart-intake', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ url })
        });

        const result = await response.json();

        if (result.success) {
            const data = result.data;
            
            // Populate Result Panel
            document.getElementById('intakeName').innerText = data.name || 'Unknown Name';
            document.getElementById('intakeCategory').innerText = data.category || 'Historical';
            document.getElementById('intakeDesc').innerText = data.description || 'No description extracted.';
            document.getElementById('intakeDistrict').innerText = data.district || 'Unknown';
            document.getElementById('intakePrice').innerText = data.financials?.ticket_range || 'Free / Unknown';
            
            // Intelligence Grid Population
            document.getElementById('intakeLogistics').innerText = data.logistics?.road_type || 'Paved';
            document.getElementById('intakeSignal').innerText = data.logistics?.mobile_signal || 'Stable';
            document.getElementById('intakeSafety').innerText = data.climate_safety?.safety_level || 'Safe';
            document.getElementById('intakeTime').innerText = data.climate_safety?.best_time || 'All Day';
            
            if (data.external_image_url) {
                document.getElementById('intakeImage').style.backgroundImage = `url('${data.external_image_url}')`;
                document.getElementById('intakeImage').style.backgroundSize = 'cover';
            } else {
                document.getElementById('intakeImage').style.backgroundImage = 'none';
            }

            // resultPanel.classList.remove('hidden');
            document.getElementById('intakeResult').classList.remove('hidden');
            urlInput.value = ''; // Clear input
        } else {
            alert('Extraction failed: ' + (result.error || result.message));
        }
    } catch (err) {
        console.error('Intake Error:', err);
        alert('An unexpected error occurred during intake.');
    } finally {
        // UI Feedback: Reset
        btn.disabled = false;
        btn.classList.remove('opacity-80', 'cursor-not-allowed');
        btnText.innerText = 'Initialize Extraction';
        spinner.classList.add('hidden');
    }
}
</script>
