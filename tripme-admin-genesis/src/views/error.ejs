<div class="premium-card p-12 text-center max-w-2xl mx-auto mt-12">
    <div class="w-20 h-20 bg-red-50 rounded-2xl flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
    </div>
    <h1 class="text-3xl font-bold text-gray-900 mb-4">Command Interrupted</h1>
    <p class="text-gray-500 mb-8 font-medium"><%= message %></p>
    
    <% if (error && error.stack) { %>
        <div class="text-left bg-gray-900 text-red-400 p-6 rounded-xl font-mono text-xs overflow-x-auto mb-8 whitespace-pre">
            <%= error.stack %>
        </div>
    <% } %>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="px-8 py-3 bg-gray-900 text-white font-bold rounded-xl hover:bg-black transition shadow-xl shadow-gray-200">
            Return to Dashboard
        </a>
        <button onclick="window.history.back()" class="px-8 py-3 bg-white border border-gray-200 text-gray-500 font-bold rounded-xl hover:bg-gray-50 transition">
            Go Back
        </button>
    </div>
</div>
