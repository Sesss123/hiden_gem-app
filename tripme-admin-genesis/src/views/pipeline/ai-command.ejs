<!-- ═══════════════════════════════════════════════════════════════════════════
     CLIENT-SIDE LOGIC
     ═══════════════════════════════════════════════════════════════════════════ -->
<script>
// ── 2. SSE REAL-TIME MONITORING ─────────────────────────────────────────────────
let pipelineStartTime = null;
const durationEl = document.getElementById('pipeline-duration');

const evtSource = new EventSource('/pipeline/live-status');

evtSource.onmessage = (e) => {
  const data = JSON.parse(e.data);
  if (data.type === 'status_update' || data.status) {
    updateMonitoringPanel(data);
    updatePipelineSteps(data);
    updateStatusBadge(data.status || 'idle');
    updateWorkerPool(data.active_workers || {});

    // Refresh keys if pipeline is active to show real-time usage
    if (data.status === 'running') {
      fetchAndRenderKeys();
    }

    if ((data.status === 'running') && !pipelineStartTime) {
      pipelineStartTime = Date.now();
    }
    if (data.status !== 'running') {
      pipelineStartTime = null;
    }
  }
};
evtSource.onerror = () => { /* Silent reconnect */ };

// Update duration ticker
setInterval(() => {
  if (pipelineStartTime) {
    const elapsed = Math.floor((Date.now() - pipelineStartTime) / 1000);
    if (durationEl) durationEl.textContent = elapsed + 's';
  }
}, 1000);

function updateMonitoringPanel(data) {
  const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
  const setWidth = (id, pct) => { const el = document.getElementById(id); if (el) el.style.width = Math.min(pct, 100) + '%'; };

  if (data.health_score !== undefined) {
    set('health-score', data.health_score + '%');
    setWidth('health-bar', data.health_score);
  }
  if (data.validation_pass_rate !== undefined) {
    set('pass-rate', data.validation_pass_rate + '%');
    setWidth('pass-bar', data.validation_pass_rate);
  }
  
  // Agent Intelligence Telemetry
  if (data.agent_confidence !== undefined) {
    set('agent-confidence-display', data.agent_confidence + '%');
    setWidth('agent-confidence-bar', data.agent_confidence);
    
    const card = document.getElementById('confidence-card');
    if (card) {
      if (data.agent_confidence > 80) card.className = 'ai-card-glass p-3 text-center border-emerald-500/30';
      else if (data.agent_confidence > 50) card.className = 'ai-card-glass p-3 text-center border-amber-500/30';
      else card.className = 'ai-card-glass p-3 text-center border-red-500/30';
    }
  }
  
  if (data.agent_tool) {
    set('agent-tool-display', data.agent_tool);
    set('agent-status-label', data.status === 'running' ? 'Active Reasoning' : 'Standby');
  }

  if (data.log_summary) {
    set('log-info', data.log_summary.INFO || 0);
    set('log-warn', data.log_summary.WARNING || 0);
    set('log-error', data.log_summary.ERROR || 0);
    set('log-critical', data.log_summary.CRITICAL || 0);
  }
  if (data.alert_status) {
    set('fail-count', data.alert_status.consecutive_failures || 0);
  }
}

function updatePipelineSteps(data) {
  const stepsCompleted = data.steps_completed || 0;
  const status = data.status || 'idle';

  const stepsDoneEl = document.getElementById('steps-done');
  if (stepsDoneEl) stepsDoneEl.textContent = stepsCompleted;
  
  const currentStepEl = document.getElementById('current-step-display');
  if (currentStepEl) currentStepEl.textContent = data.current_step || status;

  // UI feedback for Discovery
  const discoveryLog = document.getElementById('discovery-log-text');
  const consoleWrap = document.getElementById('live-console-wrap');
  const consoleEl = document.getElementById('system-console');
  const errorBanner = document.getElementById('pipeline-error-banner');
  const errorText = document.getElementById('error-message-text');

  if (status === 'running') {
    if (consoleWrap && consoleWrap.classList) consoleWrap.classList.remove('hidden');
    if (errorBanner && errorBanner.classList) errorBanner.classList.add('hidden');
  } else if (status === 'failed') {
    if (errorBanner && errorBanner.classList) {
      errorBanner.classList.remove('hidden');
      if (errorText) errorText.textContent = data.last_error || 'Unknown Pipeline Error';
    }
  } else if (status === 'idle' || status === 'completed') {
    if (errorBanner && errorBanner.classList) errorBanner.classList.add('hidden');
    if (status === 'completed') {
      if (consoleWrap && consoleWrap.classList) consoleWrap.classList.add('hidden');
    }
  }

  // --- NEURAL MONOLOGUE RENDERING ---
  const monologue = data.agent_monologue || [];
  const logs = data.last_logs || [];

  if (consoleEl) {
    let content = '';
    
    // First, render the Agent's Thoughts (Indigo)
    if (monologue.length > 0) {
      content += `<div class="p-2 mb-2 bg-indigo-500/5 border-l-2 border-indigo-500 rounded-r">
                   <p class="text-[9px] text-indigo-400 font-bold uppercase tracking-widest mb-1 italic">Agent Thought Feed</p>`;
      content += monologue.map(m => {
        const time = m.timestamp ? m.timestamp.split('T')[1].split('.')[0] : '--:--';
        return `<div class="console-line mb-1">
                  <span class="console-time">[${time}]</span> 
                  <span class="text-indigo-300 font-semibold">[${m.stage}]</span> 
                  <span class="text-gray-200 italic">"${m.monologue}"</span>
                </div>`;
      }).join('');
      content += `</div>`;
    }

    // Second, render the System Logs (Slate)
    if (logs.length > 0) {
      content += `<div class="mt-2">`;
      content += logs.map(log => {
        const parts = log.split('] ');
        const time = parts[0].replace('[', '');
        const msg = parts[1] || '';
        return `<div class="console-line opacity-70"><span class="console-time">[${time}]</span> <span class="console-msg">${msg}</span></div>`;
      }).join('');
      content += `</div>`;
    }
    
    if (consoleEl.innerHTML !== content) {
      consoleEl.innerHTML = content;
      consoleEl.scrollTop = consoleEl.scrollHeight;
    }
  }

  if (discoveryLog && data.current_step && data.current_step.includes('Discovery')) {
    discoveryLog.textContent = data.current_step;
    document.getElementById('discovery-status').classList.remove('hidden');
  }

  for (let i = 1; i <= 7; i++) {
    const nodeEl = document.getElementById(`step-node-${i}`);
    const connEl = document.getElementById(`connector-${i}`);
    if (!nodeEl) continue;

    nodeEl.className = 'step-node ';
    let stateClass = 'pending';
    if (i <= stepsCompleted) stateClass = 'done';
    else if (i === stepsCompleted + 1 && status === 'running') stateClass = 'active';
    else if (status === 'failed' && i === stepsCompleted + 1) stateClass = 'error';

    nodeEl.classList.add(stateClass);

    if (connEl) {
      connEl.className = 'step-connector' + (i <= stepsCompleted ? ' filled' : '');
    }
  }
}

function updateWorkerPool(workers) {
  const container = document.getElementById('worker-pool-container');
  const grid = document.getElementById('worker-grid');
  if (!container || !grid) return;

  const workerEntries = Object.entries(workers);
  if (workerEntries.length === 0) {
    container.classList.add('hidden');
    return;
  }

  container.classList.remove('hidden');
  grid.innerHTML = workerEntries.map(([url, info]) => {
    const siteName = url.split('/').pop().replace(/_/g, ' ');
    const isCached = info.cache_hit;
    
    return `
      <div class="p-3 bg-white/5 border border-white/10 rounded-xl flex flex-col gap-2">
        <div class="flex justify-between items-start">
          <span class="text-[10px] font-bold text-white truncate w-40">${siteName}</span>
          ${isCached ? 
            '<span class="px-1.5 py-0.5 rounded bg-emerald-500/20 text-emerald-400 text-[8px] font-bold border border-emerald-500/30">⚡ CACHED</span>' : 
            '<span class="px-1.5 py-0.5 rounded bg-indigo-500/20 text-indigo-300 text-[8px] font-bold border border-indigo-500/30">🌐 LIVE</span>'
          }
        </div>
        <div class="flex items-center gap-2">
          <div class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></div>
          <span class="text-[9px] text-gray-500 uppercase tracking-tighter">${info.step}...</span>
        </div>
      </div>
    `;
  }).join('');
}

function updateStatusBadge(status) {
  const badge = document.getElementById('pipeline-status-badge');
  const dot = document.getElementById('status-dot');
  const text = document.getElementById('status-text');
  if (!badge) return;

  badge.className = 'status-badge ';
  const map = {
    idle: ['status-idle', 'bg-gray-400'],
    running: ['status-running', 'bg-indigo-400'],
    completed: ['status-done', 'bg-emerald-400'],
    failed: ['status-failed', 'bg-red-400'],
  };
  const [cls, dotColor] = map[status] || map['idle'];
  badge.classList.add(cls);
  dot.className = `w-1.5 h-1.5 rounded-full ${dotColor} ${status === 'running' ? 'animate-pulse' : ''}`;
  text.textContent = status.toUpperCase();
}

// ── 3. API KEY MANAGER ─────────────────────────────────────────────────────────
let _keysData   = [];   // cached key list
let _activeModal  = null; // currently open modal
let _editIndex    = 0;    // index of key being edited

// ---- Fetch & Render Keys ----
async function fetchAndRenderKeys() {
  try {
    const res = await fetch('/pipeline/keys');
    if (!res.ok) return;
    const data = await res.json();
    _keysData = data.keys || [];

    renderUsageMatrix(data);
    renderKeyRows(_keysData);
  } catch (e) { /* Python offline — silent */ }
}

function renderUsageMatrix(data) {
  const container = document.getElementById('usage-matrix');
  if (!container || !data.provider_stats) return;

  const pMap = { 
    'google': { color: '#4285F4', label: 'Google' },
    'openai': { color: '#10a37f', label: 'OpenAI' },
    'anthropic': { color: '#ffffff', label: 'Anthropic' },
    'deepseek': { color: '#00e5ff', label: 'DeepSeek' },
    'groq': { color: '#f55036', label: 'Groq' }
  };

  container.innerHTML = Object.entries(data.provider_stats).map(([prov, stats]) => {
    if (stats.count === 0) return '';
    const pInfo = pMap[prov] || { color: '#888', label: prov };
    const pUsed = ((stats.used / stats.limit) * 100) || 0;
    
    return `
      <div class="p-3 border border-white/5 rounded-xl bg-white/5 backdrop-blur-sm transition-all hover:border-white/10 hover:bg-white/[0.08]">
        <div class="flex justify-between items-center mb-2">
          <span class="text-[9px] font-black uppercase tracking-wider" style="color:${pInfo.color}">${pInfo.label}</span>
          <span class="text-[9px] text-gray-500 font-bold">${stats.count} ACTIVE</span>
        </div>
        <div class="text-sm font-black text-white mb-2 flex items-baseline gap-1">
          ${stats.used.toLocaleString()} 
          <span class="text-[10px] text-gray-600 font-bold">/ ${stats.limit.toLocaleString()}</span>
        </div>
        <div class="w-full bg-white/10 rounded-full h-1 overflow-hidden">
          <div class="progress-bar h-1 rounded-full transition-all duration-700" style="width:${pUsed}%; background:${pInfo.color}; box-shadow: 0 0 10px ${pInfo.color}66"></div>
        </div>
      </div>
    `;
  }).join('');
}

function renderKeyRows(keys) {
  const container = document.getElementById('key-rows');
  if (!container) return;
  if (!keys.length) {
    container.innerHTML = '<div class="col-span-full text-center py-12 text-gray-600 text-sm">No API keys registered in the vault yet. Click <strong class="text-emerald-400 uppercase tracking-widest">Provision New Key</strong> to authorize.</div>';
    return;
  }

  container.innerHTML = keys.map(k => {
    const softLimit = k.provider === 'google' ? 2400 : (k.provider === 'openai' ? 5000 : 1000);
    const usedPct = Math.min(100, (k.count / softLimit) * 100);
    const barColor = usedPct < 50
      ? 'linear-gradient(90deg,#059669,#34d399)'
      : usedPct < 85
      ? 'linear-gradient(90deg,#d97706,#fbbf24)'
      : 'linear-gradient(90deg,#dc2626,#f87171)';
    const barGlow = usedPct < 50
      ? '0 0 10px rgba(52,211,153,0.3)'
      : usedPct < 85
      ? '0 0 10px rgba(251,191,36,0.2)'
      : '0 0 10px rgba(248,113,113,0.3)';

    const rowClass = k.active ? 'key-row active-key' : k.exhausted ? 'key-row exhausted-key' : 'key-row';
    
    // Status Badge Logic
    let statusBadge = '';
    if (k.active) {
      statusBadge = '<span class="status-badge status-running text-[8px] border-emerald-500/30 text-emerald-400 bg-emerald-500/10">ACTIVE</span>';
    } else if (k.exhausted) {
      statusBadge = '<span class="status-badge status-failed text-[8px] border-red-500/30 text-red-400 bg-red-500/10 uppercase">Exhausted</span>';
    } else if (k.source === 'env_var') {
      statusBadge = '<span class="text-[8px] font-black text-indigo-400 uppercase tracking-widest bg-indigo-500/10 px-2 py-0.5 rounded border border-indigo-500/20">ENV PROTECTED</span>';
    } else {
      statusBadge = '<span class="text-[8px] font-bold text-gray-500 uppercase tracking-widest">Standby</span>';
    }

    // Provider Config
    const pMap = { 
      'google': { color: '#4285F4', label: 'Google' },
      'openai': { color: '#10a37f', label: 'OpenAI' },
      'anthropic': { color: '#ffffff', label: 'Anthropic' },
      'deepseek': { color: '#00e5ff', label: 'DeepSeek' },
      'groq': { color: '#f55036', label: 'Groq' }
    };
    const pInfo = pMap[k.provider] || { color: '#888', label: k.provider };

    const deleteBtn = k.can_delete
      ? `<button class="key-action-btn btn-delete flex-1 justify-center" onclick="confirmDeleteKey(${k.index},'${k.nickname}')">Remove</button>`
      : `<button class="key-action-btn flex-1 justify-center opacity-30 cursor-not-allowed grayscale" title="ENV Protected" disabled>Secure</button>`;

    return `
      <div class="${rowClass}" id="krow-${k.index}">
        <div class="flex flex-col h-full">
          <!-- Top Section: Provider & Status -->
          <div class="flex items-center justify-between mb-4">
            <span class="provider-badge" style="color:${pInfo.color}; border-color:${pInfo.color}33">${pInfo.label}</span>
            ${statusBadge}
          </div>

          <!-- Mid Section: Identity -->
          <div class="mb-5 flex-grow">
            <h4 class="text-white font-black text-sm tracking-tight truncate mb-1" title="${k.nickname || 'Unnamed Key'}">
              ${k.nickname || 'Unnamed Machine Key'}
            </h4>
            <p class="font-mono text-[10px] text-gray-500 tracking-tighter opacity-70">${k.label}</p>
          </div>

          <!-- Stats Section: Progress -->
          <div class="mb-5">
            <div class="flex justify-between items-end mb-2">
              <span class="text-[9px] font-black text-gray-500 uppercase tracking-widest">Quota Consumption</span>
              <span class="text-[10px] font-black text-white">${k.count.toLocaleString()} <span class="text-gray-600 font-bold">/ ${k.limit.toLocaleString()}</span></span>
            </div>
            <div class="w-full bg-white/5 rounded-full h-1.5 overflow-hidden">
              <div style="width:${usedPct}%; background:${barColor}; box-shadow:${barGlow}" class="h-full rounded-full transition-all duration-1000"></div>
            </div>
          </div>

          <!-- Bottom Section: Actions -->
          <div class="flex gap-2">
            ${deleteBtn}
            <button class="key-action-btn btn-replace flex-1 justify-center" onclick="openReplaceModal(${k.index}, '${k.label}')">Replace</button>
          </div>
        </div>
      </div>`;
  }).join('');
}

// ---- Modal Controls ----
function openModal(id) {
  document.getElementById(id).classList.add('open');
  _activeModal = id;
}
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
  _activeModal = null;
}
document.addEventListener('keydown', e => { if (e.key === 'Escape' && _activeModal) closeModal(_activeModal); });

function openAddModal() {
  document.getElementById('new-key-input').value = '';
  document.getElementById('new-key-nick').value = '';
  document.getElementById('add-key-error').classList.add('hidden');
  openModal('add-key-modal');
}
function openReplaceModal(index, label) {
  _editIndex = index;
  document.getElementById('replace-key-label').textContent = label;
  document.getElementById('replace-key-input').value = '';
  document.getElementById('replace-key-nick').value = '';
  document.getElementById('replace-key-error').classList.add('hidden');
  openModal('replace-key-modal');
}
function openRenameModal(index, currentNick) {
  _editIndex = index;
  document.getElementById('rename-input').value = currentNick;
  openModal('rename-key-modal');
}

// ---- Show/Hide key text ----
function toggleKeyVisibility(inputId, btn) {
  const inp = document.getElementById(inputId);
  if (inp.type === 'password') {
    inp.type = 'text';
    btn.style.color = '#818cf8';
  } else {
    inp.type = 'password';
    btn.style.color = '';
  }
}

// ---- Submit: Add ----
async function submitAddKey() {
  const key  = document.getElementById('new-key-input').value.trim();
  const provider = document.getElementById('new-key-provider').value;
  const nick = document.getElementById('new-key-nick').value.trim();
  const errEl = document.getElementById('add-key-error');
  const btn   = document.getElementById('add-submit-btn');

  if (!key) { errEl.textContent = 'API key is required.'; errEl.classList.remove('hidden'); return; }

  btn.textContent = 'Adding…'; btn.disabled = true;
  try {
    const res = await fetch('/pipeline/keys', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ api_key: key, provider: provider, nickname: nick })
    });
    const data = await res.json();
    if (data.success) {
      closeModal('add-key-modal');
      showToast('✅ Key added: ' + data.label, 'success');
      fetchAndRenderKeys();
    } else {
      errEl.textContent = data.message || 'Failed to add key.';
      errEl.classList.remove('hidden');
    }
  } catch (e) {
    errEl.textContent = 'Connection error. Is the Python API running?';
    errEl.classList.remove('hidden');
  } finally { btn.textContent = 'Add Key →'; btn.disabled = false; }
}

// ---- Submit: Replace ----
async function submitReplaceKey() {
  const key  = document.getElementById('replace-key-input').value.trim();
  const nick = document.getElementById('replace-key-nick').value.trim();
  const errEl = document.getElementById('replace-key-error');

  if (!key || !key.startsWith('AIza')) {
    errEl.textContent = 'Enter a valid Google API key (starts with AIza).';
    errEl.classList.remove('hidden');
    return;
  }
  try {
    const res = await fetch(`/pipeline/keys/${_editIndex}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ api_key: key, nickname: nick || undefined })
    });
    const data = await res.json();
    if (data.success) {
      closeModal('replace-key-modal');
      showToast('🔄 Key replaced: ' + (data.label || ''), 'info');
      fetchAndRenderKeys();
    } else {
      errEl.textContent = data.message || 'Failed.';
      errEl.classList.remove('hidden');
    }
  } catch (e) { errEl.textContent = 'Connection error.'; errEl.classList.remove('hidden'); }
}

// ---- Submit: Rename ----
async function submitRename() {
  const nick = document.getElementById('rename-input').value.trim();
  if (!nick) return;
  try {
    await fetch(`/pipeline/keys/${_editIndex}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nickname: nick })
    });
    closeModal('rename-key-modal');
    fetchAndRenderKeys();
  } catch (e) { /* ignore */ }
}

// ---- Confirm: Delete ----
async function confirmDeleteKey(index, nickname) {
  if (!confirm(`Delete "${nickname}"?\n\nThis key will be removed from the rotation pool immediately.`)) return;
  try {
    const res = await fetch(`/pipeline/keys/${index}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) {
      showToast('🗑️ Key removed.', 'warn');
      fetchAndRenderKeys();
    } else {
      alert(data.message || 'Could not delete key.');
    }
  } catch (e) { alert('Connection error.'); }
}

// ---- Toast ----
function showToast(msg, type = 'info') {
  const colors = { success: '#059669', info: '#6366f1', warn: '#d97706', error: '#dc2626' };
  const t = document.createElement('div');
  t.style.cssText = `position:fixed;bottom:24px;right:24px;z-index:9999;padding:10px 18px;border-radius:12px;
    background:${colors[type] || colors.info};color:#fff;font-size:13px;font-weight:700;
    box-shadow:0 8px 24px rgba(0,0,0,0.4);animation:slideUp 0.3s ease`;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 4000);
}

// Load keys on page ready + refresh every 30s
fetchAndRenderKeys();
setInterval(fetchAndRenderKeys, 30000);

// ── 4. AI DISCOVERY MODE ───────────────────────────────────────────────────────
async function startDiscovery() {
  const promptInp = document.getElementById('discovery-prompt');
  const btn = document.getElementById('discover-btn');
  const statusEl = document.getElementById('discovery-status');
  const logEl = document.getElementById('discovery-log-text');
  
  const prompt = promptInp.value.trim();
  if (!prompt) {
    showToast('Please enter a description for discovery.', 'warn');
    return;
  }

  // UI States
  btn.disabled = true;
  btn.innerHTML = `<span>ENGAGING...</span> <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>`;
  statusEl.classList.remove('hidden');
  logEl.textContent = 'Enabling Discovery AI Engine...';

  try {
    const res = await fetch('/pipeline/discover', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt })
    });
    
    const data = await res.json();
    
    if (data.success) {
      showToast('🚀 AI Discovery Engaged!', 'success');
      logEl.textContent = 'AI is analyzing your request...';
    } else {
      showToast('❌ Discovery failed: ' + data.message, 'error');
      statusEl.classList.add('hidden');
    }
  } catch (err) {
    showToast('❌ Backend connection lost.', 'error');
    statusEl.classList.add('hidden');
  } finally {
    btn.disabled = false;
    btn.innerHTML = `<span>ENGAGE AI</span> <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/></svg>`;
    document.getElementById('stop-btn').classList.remove('hidden');
  }
}

async function abortMission() {
  if (!confirm('ABORT MISSION: Are you sure? All current reasoning and discovery for this task will be terminated.')) return;
  try {
    const res = await fetch('/pipeline/stop', { method: 'POST' });
    const data = await res.json();
    if (data.success) {
      showToast('⚠️ MISSION ABORTED. Signal sent to Neural Agent.', 'warn');
      document.getElementById('stop-btn').classList.add('hidden');
    }
  } catch (err) { showToast('Abort signal failed.', 'error'); }
}
</script>
