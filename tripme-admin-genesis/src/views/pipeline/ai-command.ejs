<%# ═══════════════════════════════════════════════════════════════════════════
    AI COMMAND CENTER — 3-Panel Intelligence Dashboard
    Left: Vision AI Analysis | Right: Real-time Monitor | Bottom: Pipeline Steps
    ═══════════════════════════════════════════════════════════════════════════ %>

<style>
  /* ── AI Command Center custom styles ── */
  .ai-card {
    background: linear-gradient(135deg, #0f0e1a 0%, #1a1835 100%);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 16px;
    color: #e2e8f0;
  }
  .ai-card-glass {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    backdrop-filter: blur(10px);
  }
  .neon-text { color: #818cf8; }
  .neon-green { color: #34d399; }
  .neon-yellow { color: #fbbf24; }
  .neon-red { color: #f87171; }

  /* Progress bar glow */
  .progress-bar-fill {
    background: linear-gradient(90deg, #6366f1, #8b5cf6);
    border-radius: 999px;
    transition: width 1s ease;
    box-shadow: 0 0 8px rgba(99,102,241,0.6);
  }
  .progress-bar-fill.green {
    background: linear-gradient(90deg, #059669, #34d399);
    box-shadow: 0 0 8px rgba(52,211,153,0.6);
  }

  /* Step timeline */
  .step-node {
    width: 40px; height: 40px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 700;
    flex-shrink: 0;
    transition: all 0.4s ease;
  }
  .step-node.done    { background: #059669; color: white; box-shadow: 0 0 12px rgba(5,150,105,0.5); }
  .step-node.active  { background: #6366f1; color: white; box-shadow: 0 0 16px rgba(99,102,241,0.8); animation: pulse-node 1.5s infinite; }
  .step-node.pending { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.3); border: 1px solid rgba(255,255,255,0.1); }
  .step-node.error   { background: #dc2626; color: white; box-shadow: 0 0 12px rgba(220,38,38,0.5); }

  .step-connector {
    flex: 1; height: 2px;
    background: rgba(255,255,255,0.08);
    position: relative; overflow: hidden;
  }
  .step-connector.filled { background: linear-gradient(90deg, #059669, #34d399); }
  .step-connector::after {
    content: '';
    position: absolute; top: 0; left: -100%; right: 0; bottom: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
    animation: shimmer 2s infinite;
  }

  @keyframes shimmer {
    0% { left: -100%; }
    100% { left: 100%; }
  }
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .spin-slow { animation: spin-slow 3s linear infinite; }

  /* Status badge */
  .status-badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 12px; border-radius: 99px;
    font-size: 10px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.1em;
  }
  .status-idle     { background: rgba(100,116,139,0.2); color: #94a3b8; border: 1px solid rgba(100,116,139,0.3); }
  .status-running  { background: rgba(99,102,241,0.2); color: #818cf8; border: 1px solid rgba(99,102,241,0.4); }
  .status-done     { background: rgba(52,211,153,0.15); color: #34d399; border: 1px solid rgba(52,211,153,0.3); }
  .status-failed   { background: rgba(248,113,113,0.15); color: #f87171; border: 1px solid rgba(248,113,113,0.3); }

  /* Key Manager Modal */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 1000;
    background: rgba(0,0,0,0.75); backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.25s ease;
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }
  .modal-box {
    background: linear-gradient(135deg, #0f0e1a 0%, #1a1835 100%);
    border: 1px solid rgba(99,102,241,0.3);
    border-radius: 20px;
    padding: 28px;
    width: min(480px, 95vw);
    max-height: 90vh; overflow-y: auto;
    transform: translateY(20px); transition: transform 0.25s ease;
    box-shadow: 0 24px 80px rgba(0,0,0,0.6), 0 0 40px rgba(99,102,241,0.1);
  }
  .modal-overlay.open .modal-box { transform: translateY(0); }

  /* Key card row — NOW GRID CARDS */
  .key-row {
    background: rgba(15, 23, 42, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 20px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 160px;
  }
  .key-row:hover {
    transform: translateY(-4px);
    background: rgba(30, 41, 59, 0.5);
    border-color: rgba(99, 102, 241, 0.3);
    box-shadow: 0 12px 30px rgba(0,0,0,0.4), 0 0 15px rgba(99,102,241,0.1);
  }
  .key-row::after {
    content: '';
    position: absolute; top: 0; right: 0; width: 80px; height: 80px;
    background: radial-gradient(circle at top right, rgba(99,102,241,0.1), transparent 70%);
  }

  .key-row.active-key    { border-color: rgba(52,211,153,0.3); background: linear-gradient(135deg, rgba(16,185,129,0.05) 0%, transparent 100%); }
  .key-row.exhausted-key { border-color: rgba(248,113,113,0.2); background: linear-gradient(135deg, rgba(239,68,68,0.05) 0%, transparent 100%); }
  .key-row.env-key       { border-color: rgba(99,102,241,0.2); }

  .key-action-btn {
    padding: 6px 14px; border-radius: 10px; font-size: 10px; font-weight: 800;
    cursor: pointer; transition: all 0.2s ease; border: 1px solid;
    text-transform: uppercase; letter-spacing: 0.08em;
    display: flex; align-items: center; gap: 6px;
  }
  .btn-replace { background: rgba(99,102,241,0.1); color: #818cf8; border-color: rgba(99,102,241,0.2); }
  .btn-replace:hover { background: #6366f1; color: white; border-color: #6366f1; }
  .btn-delete  { background: rgba(248,113,113,0.05); color: #f87171; border-color: rgba(248,113,113,0.2); }
  .btn-delete:hover  { background: #dc2626; color: white; border-color: #dc2626; }
  .btn-rename  { background: rgba(251,191,36,0.05); color: #fbbf24; border-color: rgba(251,191,36,0.2); }
  .btn-rename:hover  { background: #d97706; color: white; border-color: #d97706; }

  /* Provider crystal badge */
  .provider-badge {
    padding: 3px 8px; border-radius: 6px; font-size: 9px; font-weight: 900;
    text-transform: uppercase; letter-spacing: 0.05em;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
  }

  /* Eye toggle for password-style input */
  .pw-wrap { position: relative; }
  .pw-wrap input { padding-right: 40px; }
  .pw-eye {
    position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
    cursor: pointer; color: #6b7280;
  }
  .pw-eye:hover { color: #818cf8; }
  /* Discovery Bar Glow */
  .discovery-card {
    background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
    border: 1px solid rgba(129, 140, 248, 0.3);
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.4), 0 0 20px rgba(99,102,241,0.1);
  }
  .prompt-input {
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    transition: all 0.3s;
  }
  .prompt-input:focus {
    border-color: #818cf8;
    box-shadow: 0 0 15px rgba(129, 140, 248, 0.2);
    background: rgba(15, 23, 42, 0.8);
  }

  /* Live Terminal Console */
  .system-console {
    background: #020617;
    border: 1px solid rgba(99, 102, 241, 0.3);
    border-radius: 12px;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 11px;
    padding: 12px;
    height: 140px;
    overflow-y: auto;
    color: #94a3b8;
    box-shadow: inset 0 2px 10px rgba(0,0,0,0.5);
  }
  .console-line { border-bottom: 1px solid rgba(255,255,255,0.03); padding: 2px 0; }
  .console-time { color: #6366f1; margin-right: 8px; font-weight: bold; }
  .console-msg  { color: #cbd5e1; }
  .console-error { color: #f87171; background: rgba(239, 68, 68, 0.05); }
  
  /* Error Banner */
  .error-banner {
    background: rgba(220, 38, 38, 0.1);
    border: 1px solid rgba(220, 38, 38, 0.3);
    border-radius: 12px;
    padding: 12px 16px;
    color: #f87171;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    animation: slideInDown 0.4s ease;
  }
</style>

<!-- ── Page Header ── -->
<div class="flex items-center justify-between mb-6">
  <div>
    <p class="text-sm text-gray-400 mt-1">Real-time Monitoring • Pipeline Execution View</p>
  </div>
  <div class="flex items-center gap-3">
    <span id="pipeline-status-badge" class="status-badge status-idle">
      <span id="status-dot" class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>
      <span id="status-text"><%= pipelineStatus.status.toUpperCase() %></span>
    </span>
    <form action="/pipeline/trigger" method="POST" id="trigger-form">
      <button type="submit" id="trigger-btn"
        class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-bold px-5 py-2.5 rounded-xl transition shadow-lg shadow-indigo-900/40">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Run AI Pipeline
      </button>
    </form>
  </div>
</div>

<!-- ── NEW: AI INTELLIGENCE DISCOVERY MODE ── -->
<div class="discovery-card p-6 mb-8 overflow-hidden relative">
  <!-- Decorative Background Glow -->
  <div class="absolute -top-24 -right-24 w-64 h-64 bg-indigo-500/10 blur-[100px] rounded-full"></div>
  <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-purple-500/10 blur-[100px] rounded-full"></div>

  <div class="relative z-10">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-2xl bg-indigo-500 flex items-center justify-center shadow-lg shadow-indigo-500/20">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
      </div>
      <div>
        <h2 class="text-xl font-bold text-white tracking-tight">AI Intelligence Discovery Mode</h2>
        <p class="text-xs text-indigo-300 font-medium uppercase tracking-wider">A to Z Automated Tourism Data Engine</p>
      </div>
    </div>

    <div class="flex flex-col md:flex-row gap-4">
      <div class="flex-1 pw-wrap">
        <textarea id="discovery-prompt" rows="2" 
          class="prompt-input w-full p-4 rounded-xl text-sm outline-none resize-none"
          placeholder="Describe what you want to discover (e.g. 'All surfing spots in Arugam Bay with equipment rental info', 'Boutique hotels in Galle Fort with pool access')"></textarea>
      </div>
      <div class="flex flex-col gap-2 min-w-[180px]">
        <button id="discover-btn" onclick="startDiscovery()"
          class="h-full bg-white hover:bg-gray-100 text-indigo-900 font-black text-sm px-6 py-4 rounded-xl transition flex items-center justify-center gap-2 group">
          <span>ENGAGE AI</span>
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/></svg>
        </button>
        <button id="stop-btn" onclick="abortMission()"
          class="hidden bg-red-600/20 hover:bg-red-600/40 text-red-500 border border-red-500/30 font-bold text-[10px] px-4 py-2 rounded-xl transition flex items-center justify-center gap-2">
          <span>ABORT MISSION</span>
        </button>
      </div>
    </div>

    <!-- Live Console Display (New) -->
    <div id="live-console-wrap" class="mt-4 hidden animate-pulse">
      <p class="text-[10px] text-indigo-300 font-bold uppercase tracking-widest mb-2 flex items-center gap-2">
        <span class="w-1.5 h-1.5 bg-indigo-500 rounded-full"></span>
        Neural Telemetry Stream
      </p>
      <div id="system-console" class="system-console">
        <!-- Logs injected here -->
        <div class="console-line"><span class="console-time">[00:00:00]</span> <span class="console-msg">System ready. Awaiting engagement...</span></div>
      </div>
    </div>

    <!-- Error Banner (New) -->
    <div id="pipeline-error-banner" class="hidden error-banner mt-4">
      <svg class="w-6 h-6 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      <div>
        <p class="text-xs font-black uppercase tracking-widest">Pipeline Fault Detected</p>
        <p id="error-message-text" class="text-sm opacity-90">An unexpected error occurred during execution.</p>
      </div>
      <button onclick="document.getElementById('pipeline-error-banner').classList.add('hidden')" class="ml-auto opacity-50 hover:opacity-100">✕</button>
    </div>

    <!-- Discovery Activity Tracker -->
    <div id="discovery-status" class="hidden mt-4 p-4 ai-card-glass flex items-center justify-between">
      <div class="flex items-center gap-4">
        <div class="w-2 h-2 rounded-full bg-indigo-500 animate-ping"></div>
        <div class="flex flex-col">
          <span class="text-xs font-bold text-indigo-300 uppercase tracking-widest">AI Reasoning Layer</span>
          <span id="discovery-log-text" class="text-sm text-gray-300 mt-0.5">Initializing neural discovery...</span>
        </div>
      </div>
      <div class="flex gap-2">
         <span class="status-badge status-running text-[9px]">Analyzing Prompt</span>
         <span class="status-badge status-idle text-[9px] opacity-40">Identifying URLs</span>
      </div>
    </div>
  </div>
</div>

<div class="mb-6">
  <!-- ── REAL-TIME MONITORING PANEL ── -->
  <div class="ai-card p-6">
    <div class="flex items-center justify-between mb-5">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-emerald-600/20 border border-emerald-500/30 flex items-center justify-center">
          <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
        </div>
        <div>
          <h3 class="font-bold text-white text-sm">System Telemetry</h3>
          <p class="text-[10px] text-gray-500 uppercase tracking-widest">Live • Auto-refresh 3s</p>
        </div>
      </div>
      <div class="flex items-center gap-1.5">
        <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
        <span class="text-[10px] text-emerald-400 font-bold uppercase">LIVE</span>
      </div>
    </div>

    <!-- Metrics Grid -->
    <div class="grid grid-cols-2 gap-3 mb-5">
      <!-- Health Score -->
      <div class="ai-card-glass p-4">
        <p class="text-[10px] text-gray-500 uppercase tracking-widest mb-1">Pipeline Health</p>
        <p id="health-score" class="text-3xl font-bold text-emerald-400">
          <%= pipelineStatus.health_score %>%
        </p>
        <div class="w-full bg-white/10 rounded-full h-1.5 mt-2">
          <div id="health-bar" class="progress-bar-fill green h-1.5 rounded-full"
            :style="'width: <%= pipelineStatus.health_score %>%'"></div>
        </div>
      </div>
      <!-- Validation Pass Rate -->
      <div class="ai-card-glass p-4">
        <p class="text-[10px] text-gray-500 uppercase tracking-widest mb-1">Validation Pass</p>
        <p id="pass-rate" class="text-3xl font-bold text-indigo-400">
          <%= pipelineStatus.validation_pass_rate %>%
        </p>
        <div class="w-full bg-white/10 rounded-full h-1.5 mt-2">
          <div id="pass-bar" class="progress-bar-fill h-1.5 rounded-full"
            :style="'width: <%= pipelineStatus.validation_pass_rate %>%'"></div>
        </div>
      </div>
    </div>

    <!-- Log Summary -->
    <div class="ai-card-glass p-4 mb-4">
      <p class="text-[10px] text-gray-500 uppercase tracking-widest mb-3">Today's Log Activity</p>
      <div class="grid grid-cols-4 gap-2">
        <div class="text-center">
          <p id="log-info" class="text-xl font-bold neon-green"><%= pipelineStatus.log_summary.INFO || 0 %></p>
          <p class="text-[9px] text-gray-600 uppercase">Info</p>
        </div>
        <div class="text-center">
          <p id="log-warn" class="text-xl font-bold neon-yellow"><%= pipelineStatus.log_summary.WARNING || 0 %></p>
          <p class="text-[9px] text-gray-600 uppercase">Warn</p>
        </div>
        <div class="text-center">
          <p id="log-error" class="text-xl font-bold neon-red"><%= pipelineStatus.log_summary.ERROR || 0 %></p>
          <p class="text-[9px] text-gray-600 uppercase">Error</p>
        </div>
        <div class="text-center">
          <p id="log-critical" class="text-xl font-bold" style="color:#c084fc"><%= pipelineStatus.log_summary.CRITICAL || 0 %></p>
          <p class="text-[9px] text-gray-600 uppercase">Critical</p>
        </div>
      </div>
    </div>

    <!-- Alert Status -->
    <div class="ai-card-glass p-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-[10px] text-gray-500 uppercase tracking-widest mb-1">Alert System</p>
          <p class="text-sm text-white font-semibold">
            <span id="fail-count"><%= pipelineStatus.alert_status.consecutive_failures || 0 %></span>
            <span class="text-gray-500 font-normal text-xs"> consecutive failures</span>
          </p>
        </div>
        <span id="webhook-status"
          class="feat-badge <%= pipelineStatus.alert_status.webhook_configured ? 'detected' : 'absent' %>">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Webhook <%= pipelineStatus.alert_status.webhook_configured ? 'Active' : 'Not Set' %>
        </span>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     BOTTOM: 7-STEP PIPELINE EXECUTION VIEW
     ═══════════════════════════════════════════════════════════════════════════ -->
<div class="ai-card p-6">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-xl bg-purple-600/20 border border-purple-500/30 flex items-center justify-center">
        <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
      <div>
        <h3 class="font-bold text-white text-sm">Pipeline Execution View</h3>
        <p class="text-[10px] text-gray-500 uppercase tracking-widest">7-Step Intelligence Flow</p>
      </div>
    </div>
    <div>
      <span class="text-xs text-gray-500">Current Step: <span id="current-step-display" class="text-indigo-400 font-bold"><%= pipelineStatus.current_step %></span></span>
    </div>
  </div>

  <!-- Step Timeline — Desktop Horizontal -->
  <div class="hidden md:flex items-center gap-0 mb-6 overflow-x-auto pb-2">
    <% 
    const steps = [
      { num: 1, label: 'Trigger', icon: '⚡', desc: 'Pipeline initiated' },
      { num: 2, label: 'Scrape', icon: '🌐', desc: 'Web harvesting' },
      { num: 3, label: 'Cache', icon: '💾', desc: '24hr cache check' },
      { num: 4, label: 'Extract', icon: '🧠', desc: 'Claude AI parsing' },
      { num: 5, label: 'Validate', icon: '🔍', desc: 'Gemini cross-check' },
      { num: 6, label: 'Score', icon: '📊', desc: 'Quality threshold' },
      { num: 7, label: 'Commit', icon: '✅', desc: 'Genesis registry' },
    ];
    const stepsCompleted = pipelineStatus.steps_completed || 0;
    %>
    <% steps.forEach((step, idx) => { %>
      <% 
        let stateClass = 'pending';
        if (step.num <= stepsCompleted) stateClass = 'done';
        else if (step.num === stepsCompleted + 1 && pipelineStatus.status === 'running') stateClass = 'active';
        if (pipelineStatus.status === 'failed' && step.num === stepsCompleted + 1) stateClass = 'error';
      %>
      <div class="flex items-center" id="step-wrapper-<%= step.num %>">
        <div class="flex flex-col items-center min-w-[70px]">
          <div class="step-node <%= stateClass %>" id="step-node-<%= step.num %>" title="<%= step.desc %>">
            <% if (stateClass === 'active') { %>
              <svg class="w-4 h-4 spin-slow" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2.5" stroke-dasharray="30 10"/></svg>
            <% } else if (stateClass === 'done') { %>
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <% } else if (stateClass === 'error') { %>
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            <% } else { %>
              <span class="text-base"><%= step.icon %></span>
            <% } %>
          </div>
          <p class="text-[10px] font-bold mt-2 text-center whitespace-nowrap
            <%= stateClass === 'done' ? 'text-emerald-400' : (stateClass === 'active' ? 'text-indigo-400' : (stateClass === 'error' ? 'text-red-400' : 'text-gray-600')) %>">
            <%= step.label %>
          </p>
          <p class="text-[9px] text-gray-700 text-center whitespace-nowrap"><%= step.desc %></p>
        </div>
        <% if (idx < steps.length - 1) { %>
          <div class="step-connector <%= step.num <= stepsCompleted ? 'filled' : '' %>" id="connector-<%= step.num %>"></div>
        <% } %>
      </div>
    <% }) %>
  </div>

  <!-- Mobile Vertical Steps -->
  <div class="md:hidden space-y-3 mb-6">
    <% steps.forEach((step) => { %>
      <% 
        let stateClass = 'pending';
        if (step.num <= stepsCompleted) stateClass = 'done';
        else if (step.num === stepsCompleted + 1 && pipelineStatus.status === 'running') stateClass = 'active';
      %>
      <div class="flex items-center gap-3 ai-card-glass p-3">
        <div class="step-node <%= stateClass %> w-8 h-8 text-sm">
          <% if (stateClass === 'done') { %>✓<% } else if (stateClass === 'active') { %>⟳<% } else { %><%= step.icon %><% } %>
        </div>
        <div>
          <p class="text-xs font-bold text-white"><%= step.label %></p>
          <p class="text-[10px] text-gray-500"><%= step.desc %></p>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Step Details Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <div class="ai-card-glass p-3 text-center">
      <p class="text-[9px] text-gray-600 uppercase tracking-widest mb-1">Processed</p>
      <p id="steps-done" class="text-2xl font-bold text-white"><%= pipelineStatus.steps_completed %></p>
      <p class="text-[9px] text-gray-600">of <%= pipelineStatus.total_steps %> steps</p>
    </div>
    <div class="ai-card-glass p-3 text-center">
      <p class="text-[9px] text-gray-600 uppercase tracking-widest mb-1">Duration</p>
      <p id="pipeline-duration" class="text-2xl font-bold neon-text">—</p>
      <p class="text-[9px] text-gray-600">seconds elapsed</p>
    </div>
    <div class="ai-card-glass p-3 text-center border-indigo-500/20" id="confidence-card">
      <p class="text-[9px] text-gray-600 uppercase tracking-widest mb-1">Agent Confidence</p>
      <p id="agent-confidence-display" class="text-2xl font-bold neon-green">100%</p>
      <div class="w-full bg-white/5 h-1 rounded-full mt-1 overflow-hidden">
        <div id="agent-confidence-bar" class="h-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)] transition-all duration-500" style="width: 100%"></div>
      </div>
    </div>
    <div class="ai-card-glass p-3 text-center border-purple-500/20" id="tool-card">
      <p class="text-[9px] text-gray-600 uppercase tracking-widest mb-1">Intelligence Tool</p>
      <p id="agent-tool-display" class="text-lg font-bold neon-text">Neural Core</p>
      <p class="text-[9px] text-gray-600 uppercase tracking-tighter" id="agent-status-label">Standby</p>
    </div>
  
