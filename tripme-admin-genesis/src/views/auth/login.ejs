<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | TripMeAI Genesis</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f5f4f0; }
        .login-card { background: #ffffff; border: 1px solid #e8e7e2; border-radius: 24px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.05); }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-6">

    <div class="login-card w-full max-w-md p-10">
        <div class="text-center mb-10">
            <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center text-white font-bold text-xl mx-auto mb-4 italic">T</div>
            <h1 class="text-2xl font-bold text-gray-900 tracking-tight">TripMeAI Genesis</h1>
            <p class="text-gray-500 text-sm mt-2 font-medium">Internal Command Center v2.0</p>
        </div>

        <% if (error) { %>
            <div class="mb-6 p-4 bg-red-50 border border-red-100 rounded-xl text-red-600 text-sm font-medium flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <%= error %>
            </div>
        <% } %>

        <form action="/auth/login" method="POST" class="space-y-6">
            <div class="space-y-2">
                <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest pl-1">Admin Email</label>
                <input type="email" name="email" required placeholder="admin@tripme.ai" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-5 py-3.5 text-sm focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition">
            </div>
            
            <div class="space-y-2">
                <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest pl-1">Security Token</label>
                <input type="password" name="password" required placeholder="••••••••" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-5 py-3.5 text-sm focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition">
            </div>

            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-4 rounded-xl transition shadow-xl shadow-indigo-100 flex items-center justify-center gap-2">
                Authorize Access
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </button>
        </form>

        <div class="mt-10 pt-10 border-t border-gray-50 text-center">
            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest leading-loose">
                Authorized Personnel Only &bull; Secured with JWT & Session Tracking
            </p>
        </div>
    </div>

</body>
</html>
