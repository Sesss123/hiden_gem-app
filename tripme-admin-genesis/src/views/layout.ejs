<!DOCTYPE html>
<html lang="en" x-data="{ mobileMenuOpen: false }">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TripMeAI Genesis | <%= title || 'Admin' %></title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        window.handleStopPipeline = async (runId) => {
            const result = await Swal.fire({
                title: 'Emergency Stop?',
                text: "This will halt all active AI extractions for this run immediately.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, Kill Process'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/admin/stop-pipeline/${runId}`, { method: 'POST' });
                    const data = await response.json();
                    Swal.fire('Ordered', data.message, 'success').then(() => location.reload());
                } catch (err) {
                    Swal.fire('Error', 'Failed to reach command center', 'error');
                }
            }
        };
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f5f4f0; color: #1a1917; }
        .sidebar { background-color: #1a1917; transition: transform 0.3s ease-in-out; }
        .sidebar-link-active { background-color: rgba(255,255,255,0.05); color: #fff; border-right: 3px solid #534AB7; }
        .premium-card { background: #ffffff; border: 1px solid #e8e7e2; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.01), 0 2px 4px -1px rgba(0,0,0,0.01); }
        .glass-nav { backdrop-filter: blur(8px); background: rgba(245, 244, 240, 0.8); }
        
        @media (max-width: 1023px) {
            .sidebar { transform: translateX(-100%); z-index: 50; }
            .sidebar.mobile-open { transform: translateX(0); }
            .main-content { margin-left: 0 !important; }
        }
    </style>
</head>
<body class="flex min-h-screen">

    <!-- Mobile Sidebar Backdrop -->
    <div x-show="mobileMenuOpen" 
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @click="mobileMenuOpen = false"
         class="fixed inset-0 bg-black/50 z-40 lg:hidden"></div>

    <!-- Sidebar -->
    <aside :class="{ 'mobile-open': mobileMenuOpen }" 
           class="sidebar w-64 flex-shrink-0 text-gray-400 flex flex-col fixed inset-y-0 lg:translate-x-0">
        <div class="p-6 border-b border-gray-800 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center text-white font-bold">T</div>
                <span class="text-white font-semibold text-lg tracking-tight">TripMeAI <span class="text-xs font-normal text-gray-500 uppercase">Genesis</span></span>
            </div>
            <!-- Close btn for mobile -->
            <button @click="mobileMenuOpen = false" class="lg:hidden text-gray-500 hover:text-white">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <nav class="flex-1 mt-6 px-4 space-y-1 overflow-y-auto">
            <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/5 transition <%= path === '/' ? 'sidebar-link-active' : '' %>">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                <span class="text-sm font-medium">Dashboard</span>
            </a>
            
            <div class="pt-4 pb-2 px-4 text-xs font-semibold text-gray-600 uppercase tracking-wider">Data Operations</div>
            <a href="/places" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/5 transition <%= path.startsWith('/places') ? 'sidebar-link-active' : '' %>">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                <span class="text-sm font-medium">Places Registry</span>
            </a>
            <a href="/reviews" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/5 transition <%= path.startsWith('/reviews') ? 'sidebar-link-active' : '' %>">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span class="text-sm font-medium">Review Queue</span>
                <% if (locals.pendingCount > 0) { %>
                    <span class="ml-auto bg-indigo-600 text-white text-[10px] px-2 py-0.5 rounded-full"><%= pendingCount %></span>
                <% } %>
            </a>
            <a href="/media" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/5 transition <%= path.startsWith('/media') && path !== '/media/vision-lab' ? 'sidebar-link-active' : '' %>">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <span class="text-sm font-medium">Media Vault</span>
            </a>
            <a href="/media/vision-lab" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/5 transition <%= path === '/media/vision-lab' ? 'sidebar-link-active' : '' %>">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <span class="text-sm font-medium">Neural Vision Lab</span>
                <span class="ml-auto text-[9px] bg-indigo-500/20 text-indigo-400 px-1.5 py-0.5 rounded border border-indigo-500/30 font-black tracking-widest uppercase">LAB</span>
            </a>

            <div class="pt-4 pb-2 px-4 text-xs font-semibold text-gray-600 uppercase tracking-wider">System</div>
            <a href="/pipeline" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/5 transition <%= path.startsWith('/pipeline') && !path.startsWith('/pipeline/ai-command') ? 'sidebar-link-active' : '' %>">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                <span class="text-sm font-medium">AI Pipelines</span>
            </a>
            <a href="/pipeline/ai-command" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/5 transition <%= path.startsWith('/pipeline/ai-command') ? 'sidebar-link-active' : '' %>">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2-2v10a2 2 0 002 2z"/></svg>
                <span class="text-sm font-medium">AI Command Center</span>
                <span class="ml-auto text-[9px] bg-indigo-600/80 text-white px-1.5 py-0.5 rounded font-black tracking-tight">NEW</span>
            </a>

            <% if (user && user.role === 'super_admin') { %>
                <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/5 transition <%= path.startsWith('/admin/users') ? 'sidebar-link-active' : '' %>">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    <span class="text-sm font-medium">Admin Users</span>
                </a>
                <a href="/admin/scheduler" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/5 transition <%= path.startsWith('/admin/scheduler') ? 'sidebar-link-active' : '' %>">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span class="text-sm font-medium">Job Scheduler</span>
                    <span class="ml-auto text-[9px] bg-emerald-600/80 text-white px-1.5 py-0.5 rounded font-black tracking-tight">AUTO</span>
                </a>

                <a href="/admin/system" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/5 transition <%= path.startsWith('/admin/system') ? 'sidebar-link-active' : '' %>">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path></svg>
                    <span class="text-sm font-medium">Server Controls</span>
                </a>
                <a href="/admin/logs" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/5 transition <%= path.startsWith('/admin/logs') ? 'sidebar-link-active' : '' %>">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <span class="text-sm font-medium">Audit Logs</span>
                </a>
            <% } %>
        </nav>

        <% if (user) { %>
            <div class="p-4 border-t border-gray-800">
                <div class="bg-gray-800/50 rounded-xl p-4">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 bg-gray-700 rounded-full flex items-center justify-center text-gray-300 font-bold">
                            <%= user.name.charAt(0) %>
                        </div>
                        <div>
                            <p class="text-white text-sm font-medium"><%= user.name %></p>
                            <p class="text-gray-500 text-[10px] uppercase font-bold"><%= user.role.replace('_', ' ') %></p>
                        </div>
                    </div>
                    <a href="/auth/logout" class="block w-full text-center py-2 px-4 bg-gray-700 hover:bg-red-600/20 hover:text-red-400 text-gray-300 text-xs font-semibold rounded-lg transition">
                        Sign Out
                    </a>
                </div>
            </div>
        <% } %>
    </aside>

    <!-- Main Content -->
    <main class="main-content flex-1 lg:ml-64 min-h-screen flex flex-col">
        <!-- Topbar -->
        <header class="h-16 glass-nav flex items-center justify-between px-4 lg:px-8 sticky top-0 z-10 border-b border-gray-200">
            <div class="flex items-center gap-4">
                <!-- Hamburger btn -->
                <button @click="mobileMenuOpen = true" class="lg:hidden p-2 text-gray-600 hover:bg-gray-100 rounded-lg">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
                <h1 class="font-bold text-gray-800 tracking-tight text-lg lg:text-xl truncate max-w-[200px] md:max-w-none"><%= title %></h1>
            </div>
            
            <div class="flex items-center gap-6">
                <!-- System Status -->
                <div class="flex items-center gap-2 px-3 py-1 bg-green-50 text-green-700 rounded-full border border-green-100 hidden md:flex">
                    <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                    <span class="text-xs font-bold uppercase tracking-widest">Online</span>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <div class="p-4 lg:p-8 flex-1">
            <%- body %>
        </div>

        <footer class="p-6 lg:p-8 text-center text-gray-400 text-[10px] lg:text-xs">
            &copy; 2026 TripMeAI Genesis &bull; Internal Operations Platform
        </footer>
    </main>

</body>
</html>

